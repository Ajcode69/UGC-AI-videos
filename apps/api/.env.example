# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Google Gemini ───────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Veo (Vertex AI) ──────────────────────────
# Used for video generation. You will need Vertex AI credentials.
# Google Cloud project ID and location for Veo.
VERTEX_AI_PROJECT_ID=your_gcp_project_id
VERTEX_AI_LOCATION=us-central1

# ── Google Custom Search (for web_search tool) ─────
# Get API key from: https://console.cloud.google.com/apis/credentials
# Create search engine at: https://programmablesearchengine.google.com/
# Leave blank to use simulated search fallback (good for dev)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ── Supabase ────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_BUCKET=ugc-videos

